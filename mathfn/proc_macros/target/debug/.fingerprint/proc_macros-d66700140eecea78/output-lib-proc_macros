;\n}\n\nfn main() {\n    // Calling the method is still fine, as i32 implements Debug.\n    some_func(5i32);\n\n    // This would fail to compile now:\n    // struct WithoutDebug;\n    // some_func(WithoutDebug);\n}\n```\n\nRust only looks at the signature of the called function, as such it must\nalready specify all requirements that will be used for every type parameter.\n"},"level":"error","spans":[{"file_name":"src\\lib.rs","byte_start":382,"byte_end":393,"line_start":24,"line_end":24,"column_start":46,"column_end":57,"is_primary":true,"text":[{"text":"\tfn parse<A: Arch>(&mut self, expr: Expr) -> Expended<A> {","highlight_start":46,"highlight_end":57}],"label":"the trait `Ord` is not implemented for `A`","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[{"message":"required by a bound in `Expended`","code":null,"level":"note","spans":[{"file_name":"C:\\sandbox\\matrix\\matlib\\mathfn\\src\\lib.rs","byte_start":4222,"byte_end":4225,"line_start":196,"line_end":196,"column_start":31,"column_end":34,"is_primary":true,"text":[{"text":"pub struct Expended<A: Arch + Ord>(SortedVec<Signed<MulTable<A>>>)","highlight_start":31,"highlight_end":34}],"label":"required by this bound in `Expended`","suggested_replacement":null,"suggestion_applicability":null,"expansion":null}],"children":[],"rendered":null},{"message":"consider further restricting type parameter `A` with trait `Ord`","code":null,"level":"help","spans":[{"file_name":"src\\lib.rs","byte_start":354,"byte_end":354,"line_start":24,"line_end":24,"column_start":18,"column_end":18,"is_primary":true,"text":[{"text":"\tfn parse<A: Arch>(&mut self, expr: Expr) -> Expended<A> {","highlight_start":18,"highlight_end":18}],"label":null,"suggested_replacement":" + std::cmp::Ord","suggestion_applicability":"MachineApplicable","expansion":null}],"children":[],"rendered":null}],"rendered":"\u001b[1m\u001b[91merror[E0277]\u001b[0m\u001b[1m\u001b[97m: the trait bound `A: Ord` is not satisf